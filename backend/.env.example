# ============================================================================
# AI Code Assistant - Environment Configuration Template
# ============================================================================
# Copy this file to .env and fill in your actual values
# Never commit .env to version control!

# ============================================================================
# Flask Configuration
# ============================================================================
SECRET_KEY=your-secret-key-here
DEBUG=True

# ============================================================================
# MongoDB Configuration
# ============================================================================
# Local MongoDB
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/dbname

# MongoDB Atlas (Cloud) - Alternative
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/

DB_NAME=ai_code_assistant

# ============================================================================
# OpenAI Configuration (REQUIRED)
# ============================================================================
# LLM Provider Configuration
LLM_PROVIDER=openrouter

# OpenRouter Configuration
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct
# ============================================================================
# File Upload Configuration
# ============================================================================
UPLOAD_FOLDER=./uploads
MAX_FILE_SIZE=10485760

# ============================================================================
# FAISS & Embeddings Configuration
# ============================================================================
VECTOR_DB_PATH=./vector_db
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# ============================================================================
# Code Analysis Configuration
# ============================================================================
PYLINT_THRESHOLD=7.0
FLAKE8_MAX_LINE_LENGTH=88
FLAKE8_IGNORE=E501,W503
MAX_COMPLEXITY=10
MAX_FUNCTION_LENGTH=50

# ============================================================================
# GitHub/GitLab Integration (Optional)
# ============================================================================
# Get GitHub token from: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_token_here
# Get GitLab token from: https://gitlab.com/-/profile/personal_access_tokens
GITLAB_TOKEN=
ENABLE_GIT_INTEGRATION=True

# ============================================================================
# RAG Configuration
# ============================================================================
RAG_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.7

# ============================================================================
# Documentation Configuration
# ============================================================================
DOC_FORMAT=markdown
INCLUDE_EXAMPLES=True

# ============================================================================
# Cleanup & Maintenance Configuration
# ============================================================================
CLEANUP_UPLOADS_AFTER_HOURS=24
MAX_ANALYSIS_HISTORY=100

# ============================================================================
# Logging Configuration
# ============================================================================
LOG_LEVEL=INFO
LOG_FILE=app.log

# ============================================================================
# CORS Configuration
# ============================================================================
CORS_ORIGINS=*

# ============================================================================
# Rate Limiting (Optional)
# ============================================================================
ENABLE_RATE_LIMITING=False
RATE_LIMIT_PER_MINUTE=60
